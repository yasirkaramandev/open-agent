{
  "name": "opencalc-studio",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "OpenCalc Studio — premium, accessible, offline-capable React calculator. Pure calculation engine + project scaffold.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "generate:icons": "node scripts/generate-pwa-icons.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
